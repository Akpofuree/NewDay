# PostgreSQL connection string from Railway, Render, Neon, Supabase, etc.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Public app URL and CORS allowlist. Use comma-separated origins for previews.
APP_URL="http://localhost:3000"
VITE_API_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"

# Use a long random value, at least 32 characters.
JWT_SECRET="replace_with_a_very_long_random_secret"

# Google OAuth client id used to verify POST /auth/google idToken values.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"

# Anthropic Claude API key for POST /tasks/:id/ai-guide.
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"

# Resend API key for email sending (required for email verification, password reset, etc.)
RESEND_API_KEY="your_resend_api_key_here"

# Optional SMTP settings. Without these, reset links are logged in development.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="NewDay <no-reply@example.com>"

# Optional webhook for critical alerts.
CRITICAL_ALERT_WEBHOOK_URL=""
